# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
.venv/
venv/
env/

# ── Node / Frontend ───────────────────────────────────────────────────────────
Frontend/node_modules/
Frontend/dist/
Frontend/dist-ssr/
Frontend/.output/
Frontend/.vinxi/
Frontend/.tanstack/
Frontend/.nitro/
Frontend/*.local

# ── Bot generated output (large files, regenerated on each run) ───────────────
Bot/Output/*.json
Bot/Cache/
Bot/__pycache__/

# Keep HTML source pages (needed for HITL display), but exclude screenshot JPEGs
# and the saved-page asset folders (regenerated by bot runs)
Bot/HTML/*.jpg
Bot/HTML/*.jpeg
Bot/HTML/all_models_files/

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.suo
*.idea/
.vscode/*
!.vscode/extensions.json

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-error.log*
